# YouTube Data API Key (用于解析频道、获取视频封面和详情)
YOUTUBE_API_KEY=your_youtube_data_api_key_here

# 聚合接收端配置 (非必填，用于推送到自建的服务)
ENABLE_WEBHOOK_PUSH=false
APP_HOST=http://your-aggregator-server.com
YT_WORKER_TOKEN=your_auth_token_here

# 本监控服务配置
YT_CALLBACK_DOMAIN=yt.yourdomain.com # 必须是外网能访问的域名或 IP，用于接收 Google WebSub 回调
YT_MONITOR_PORT=8000
YT_ADMIN_KEY=your_admin_api_key_here # 用于保护本服务的增删频道 API

# Telegram 推送配置 (若需要直接推送到 TG，需要开启下方的开关并填入 Token 和 Chat ID)
ENABLE_TG_PUSH=false
TG_BOT_TOKEN=
TG_CHAT_ID=
